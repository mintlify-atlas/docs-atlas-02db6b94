  "keyFeatures": [
    "Multi-format posts (photos, text, video)",
    "Content collections for organizing posts",
    "Built-in URL shortening",
    "Full-text search with PostgreSQL",
    "User authentication with admin controls",
    "S3-compatible file storage",
    "Flexible content visibility (public, private, draft, unlisted)",
    "Self-hosted and Docker-ready"
