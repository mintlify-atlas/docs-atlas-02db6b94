  "publicApiSurface": [
    "POST /api/data/all_posts - Get all posts",
    "POST /api/data/modify/posts - Create or modify posts",
    "POST /api/data/publish - Publish posts",
    "POST /api/data/publish/file - Publish files",
    "POST /api/data/get_all_collections - Get collections",
    "POST /api/data/create_share_link - Create short URLs",
    "POST /api/data/search - Search posts",
    "GET /api/data/get_user_basic_info/[slug] - Get user info",
    "POST /api/data/settings - Manage settings",
    "GET /api/data/files/[...slug] - Access files",
    "POST /api/auth/[...all] - Authentication endpoints"
  ]
